{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    },
    "app/api/data-access-requests/*/generate/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/dsar-deadlines/route.ts": {
      "maxDuration": 60
    },
    "app/api/tools/cookie-scanner/route.ts": {
      "maxDuration": 60
    },
    "app/api/scripts/discover/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/cleanup-audit-log",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/dsar-deadlines",
      "schedule": "0 8 * * *"
    }
  ]
}
